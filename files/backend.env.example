# Copy to .env for local development — never commit .env to git

# Your Antigravity / Gemini API key
GEMINI_API_KEY=your_api_key_here

# Antigravity endpoint (OpenAI-compatible)
ANTIGRAVITY_ENDPOINT=https://api.antigravity.ai/v1/chat/completions

# Comma-separated list of allowed frontend origins
# Local dev: http://localhost:5173
# Production: add your Cloud Run frontend URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional tuning
MAX_TOKENS=1500
TEMPERATURE=0.7
