# Copy to .env.local for local development — never commit .env.local to git

# Point to your local backend during development
VITE_API_BASE_URL=http://localhost:8000

# Production (set as --build-arg in docker build, NOT stored here):
# VITE_API_BASE_URL=https://votewise-backend-xxxxxxxxxx-uc.a.run.app

# Firebase (Service 3 — Firestore session persistence)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=votewise-494715.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=votewise-494715.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google Analytics 4 (Service 2)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
